# Tenant configs with real credentials (only .yaml.example is tracked)
connections/*.yaml
!connections/*.yaml.example

# Generated schemas and catalogs (can be regenerated)
connectors/**/schemas/
connectors/**/configured_catalog.json
connectors/**/state.json

# Legacy: per-tenant CronWorkflow dirs were generated locally by the
# now-removed sync-flows.sh. Reconcile applies CronWorkflows in-cluster, so
# nothing writes these anymore; pattern kept so any stale local dirs stay
# ignored. (workflows/onetime/*.tpl are tracked and unaffected.)
workflows/*/
!workflows/templates/
!workflows/schedules/
!workflows/onetime/
