apiVersion: v1
kind: Secret
metadata:
  name: insight-bitbucket-cloud-main
  labels:
    app.kubernetes.io/part-of: insight
  annotations:
    insight.cyberfabric.com/connector: bitbucket-cloud
    insight.cyberfabric.com/source-id: bitbucket-cloud-main
    # bitbucket_username is optional under Option A (Workspace Access Token);
type: Opaque
stringData:
  # Option A — Workspace Access Token (recommended):
  #   bitbucket_token is the workspace access token.
  #   bitbucket_username can be omitted or left empty.
  #
  # Option B — App Password / Personal API Token:
  #   bitbucket_token is the password.
  #   bitbucket_username is required (account email or username).
  bitbucket_token: "CHANGE_ME"
  bitbucket_username: ""
  bitbucket_workspaces: '["my-workspace"]'
  bitbucket_start_date: "2024-01-01"
  bitbucket_skip_forks: "true"
