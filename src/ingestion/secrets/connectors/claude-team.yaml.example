apiVersion: v1
kind: Secret
metadata:
  name: insight-claude-team-main
  labels:
    app.kubernetes.io/part-of: insight
  annotations:
    insight.cyberfabric.com/connector: claude-team
    insight.cyberfabric.com/source-id: claude-team-main
type: Opaque
stringData:
  # Required — UUID of the claude.ai organisation we collect data for.
  # Find it via DevTools console on claude.ai:
  #   fetch('/api/organizations').then(r=>r.json()).then(console.table)
  # Pick the row that matches your org name, copy the `uuid` column.
  claude_org_id: "CHANGE_ME"

  # NOTE on auth: there is NO sessionKey / API key in this Secret.
  # Authentication is handled by the `claude-team-proxy` service that
  # this connector talks to. The sessionKey lives in a separate
  # Helm-managed Secret attached to the proxy Deployment. Rotate via:
  #
  #   helm upgrade claude-team-proxy ./helm \
  #     --namespace insight \
  #     --reuse-values \
  #     --set-string sessionKey="<new-sessionKey-from-claude.ai-DevTools>"
  #
  # When sessionKey expires, the proxy starts returning HTTP 401 for
  # /api/* — the connector will mark its sync as failed, alerting
  # operators. The connector itself never sees credentials.

  # NOTE: insight_source_id is NOT a stringData field. It is injected
  # from the insight.cyberfabric.com/source-id annotation above.
