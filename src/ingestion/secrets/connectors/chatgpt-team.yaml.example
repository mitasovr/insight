apiVersion: v1
kind: Secret
metadata:
  name: insight-chatgpt-team-main
  labels:
    app.kubernetes.io/part-of: insight
  annotations:
    insight.cyberfabric.com/connector: chatgpt-team
    insight.cyberfabric.com/source-id: chatgpt-team-main
type: Opaque
stringData:
  # Required — ChatGPT workspace account UUID (used by /accounts/{id}/* endpoints).
  # Find it in the logged-in browser at https://chatgpt.com/api/auth/session
  # (or in DevTools → Network on a /backend-api/accounts/... request).
  chatgpt_account_id: "CHANGE_ME"

  # Optional — ChatGPT organization UUID (e.g. org-...), used ONLY by the
  # subscription streams (/subscriptions/{org_id}/*). Leave blank for
  # analytics-viewer accounts with no billing visibility — those streams then
  # tolerate the 403/404 and the sync stays green (matches descriptor
  # optional_fields). Same source as above.
  chatgpt_org_id: ""

  # Required — base URL of the customer-deployed chatgpt-team-proxy.
  # The proxy lives in a separate repo and is hosted by the customer:
  #   https://gitlab.constr.dev/insight/secure-enclave → proxies/chatgpt_team/
  # No default — the operator MUST set the actual customer-exposed endpoint.
  proxy_url: "https://chatgpt-team-proxy.customer.example.com"

  # Required — bearer token Insight sends to the proxy on every request:
  #   Authorization: Bearer <proxy_auth_token>
  # Must match PROXY_AUTH_TOKEN on the proxy container. Generated by the
  # customer (e.g. `openssl rand -hex 32`) and shared out-of-band.
  proxy_auth_token: "CHANGE_ME"

  # Optional — earliest date (YYYY-MM-DD) to backfill the per-day streams
  # (chat_activity, codex_user_daily). Default: 7 days ago. Set to
  # "2026-01-14" for a full historical backfill.
  # start_date: "2026-01-14"

  # NOTE: there is NO chatgpt.com session or access_token in this Secret.
  # The session cookie lives only inside the customer's proxy container
  # (installed via POST /admin/session-key); the proxy derives + refreshes
  # the access_token. Insight never sees either.

  # NOTE: insight_source_id is NOT a stringData field. It is injected from
  # the insight.cyberfabric.com/source-id annotation above.
