apiVersion: v1
kind: Secret
metadata:
  name: insight-workday-main
  labels:
    app.kubernetes.io/part-of: insight
  annotations:
    insight.cyberfabric.com/connector: workday
    insight.cyberfabric.com/source-id: workday-main
type: Opaque
stringData:
  workday_base_url: "CHANGE_ME"                # https://<host>/ccx/service/customreport2/<workday_tenant>
  workday_isu_username: "CHANGE_ME"            # Integration System User
  workday_isu_password: "CHANGE_ME"            # ISU password
  workday_workers_report_path: "CHANGE_ME"     # <report_owner>/<Report_Name>
  workday_leave_report_path: "CHANGE_ME"       # <report_owner>/<Report_Name>
  workday_start_date: "2020-01-01"             # Optional: time-off history start date
