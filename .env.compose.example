# Insight platform — docker-compose dev stack.
#
# Copy to `.env.compose` (gitignored — see .gitignore for `.env.*`) and
# tweak as needed. Loaded by:
#
#   ./dev-compose.sh up        (which calls `docker compose --env-file=.env.compose`)
#   ./dev-compose.sh build
#
# All values are optional — defaults below match what the script falls
# back to when a key is unset.
# ─────────────────────────────────────────────────────────────────────

# ── Auto-reload ───────────────────────────────────────────────────────
# When true, EVERY backend container wraps its binary in `watchexec`. A
# change to the bind-mounted host binary (touched by dev-compose.sh build)
# triggers SIGTERM + respawn. Unset = bare exec, matching prod.
#
# This is the ONLY switch that causes container processes to restart.
# DO NOT set this in any k8s manifest. Compose-only.
ENABLE_AUTO_RELOAD=true

# ── Frontend mode ────────────────────────────────────────────────────
# How the frontend ships into the stack:
#   dev    : Vite dev server with HMR. Source bind-mounted from
#            ${INSIGHT_FRONT_PATH}. Fastest dev loop; pnpm install runs
#            on first start.
#   built  : nginx + dist/ bind-mounted from host. Run
#            `./dev-compose.sh build frontend` to produce dist/. No HMR.
#   ghcr   : Pull ${FRONTEND_IMAGE} from a registry. No host repo
#            needed.
FRONTEND_MODE=dev

# Path to the insight-front checkout relative to insight/. Default
# assumes the sibling layout `cf/insight + cf/insight-front`.
INSIGHT_FRONT_PATH=../insight-front

# Override the published image for FRONTEND_MODE=ghcr. Leave blank for
# the default (ghcr.io/constructorfabric/insight-front:latest).
FRONTEND_IMAGE=

# ── Backend image overrides (per service) ─────────────────────────────
# When set, that service pulls the named image instead of building
# locally — dev-compose.sh up detects these and skips the corresponding
# host-side build step, and generates an override that drops the bind
# mount for the service.
#
# Equivalent CLI: `./dev-compose.sh up --from-ghcr=api-gateway,identity`
API_GATEWAY_IMAGE=
ANALYTICS_API_IMAGE=
IDENTITY_IMAGE=

# ── Host port mapping ─────────────────────────────────────────────────
# Change these if 8080/8081/8082/3000/3306/8123/6379 are already in use.
API_GATEWAY_PORT=8080
ANALYTICS_API_PORT=8081
IDENTITY_PORT=8082
FRONTEND_PORT=3000

MARIADB_PORT=3306
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
REDIS_PORT=6379

REDPANDA_KAFKA_PORT=19092
REDPANDA_PROXY_PORT=18082
REDPANDA_SCHEMA_PORT=18081
REDPANDA_ADMIN_PORT=19644

# ── Database credentials ──────────────────────────────────────────────
# Per the project convention secrets live in dotenv for local dev.
# They are ONLY for the local stack — change before any shared use.
MARIADB_ROOT_PASSWORD=root-local
MARIADB_USER=insight
MARIADB_PASSWORD=insight-local

CLICKHOUSE_USER=insight
CLICKHOUSE_PASSWORD=insight-local

# ── Tenant / OIDC ─────────────────────────────────────────────────────
# Default tenant for header-less callers (analytics-api + identity).
# Replace with the UUID present in your persons.insight_tenant_id.
TENANT_DEFAULT_ID=00000000-df51-5b42-9538-d2b56b7ee953

# The api-gateway dev command uses no-auth.yaml (auth_disabled=true) by
# default — all requests get root context. The plugin demands a non-empty
# issuer_url even when auth is off, so no-auth.yaml ships with a
# placeholder (https://no-auth.local/oauth2/default) that is never
# actually contacted.
#
# To enable real OIDC: edit src/backend/services/api-gateway/config/no-auth.yaml
# directly (it's bind-mounted; watchexec reloads). Flip auth_disabled to
# false, set oidc-authn-plugin.issuer_url + audience and
# auth-info.client_id / scopes. See CONTRIBUTING.md "Switch the gateway
# to real OIDC".
#
# The variables below are kept for the frontend (which reads
# VITE_OIDC_ISSUER / VITE_OIDC_CLIENT_ID).
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_REDIRECT_URI=http://localhost:3000/callback
OIDC_AUDIENCE=
OIDC_CLIENT_SECRET=

# ── Dev impersonation ─────────────────────────────────────────────────
# When set, the Vite frontend skips OIDC and binds every request to the
# `persons` row whose value_id == this email. Useful with AUTH_DISABLED=true
# on the gateway. Leave empty for the real OIDC flow.
#
# IMPORTANT: a matching person must exist in identity's MariaDB. Run
# `./dev-compose.sh seed identity` (or `./dev-compose.sh seed` for the
# whole demo dataset) after first up to insert one. See CONTRIBUTING.md
# "Dev impersonation seed".
VITE_DEV_USER_EMAIL=

# ── Frontend security headers ─────────────────────────────────────────
# CSP value passed to nginx (built / ghcr modes). Leave empty unless you
# need to widen the policy for an embedded analytics widget etc.
CSP_REMOTE=

# ── Log level ─────────────────────────────────────────────────────────
# Rust services honour RUST_LOG (env_logger style). info | debug | trace.
RUST_LOG=info

# ── Out-of-scope reminders ────────────────────────────────────────────
# Airbyte and Argo Workflows are NOT in this stack. They need k8s.
# Install one of orbstack / k3d / kind and use the existing helmfile
# path (dev-up.sh) for those — see CONTRIBUTING.md "Beyond compose".
