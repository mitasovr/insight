.env
.env.local
.env.*
!.env.*.example
up-orb.sh
__pycache__/
*.pyc
.venv/
*.egg-info/
dist/
build/
uv.lock
.DS_Store
local
access

# Exceptions for the gitops-sample starter under docs/deploy — `local`
# is a valid env name in the committed template and the `local/`
# subdirectories must ship.
!docs/deploy/bootstrap/local/
!docs/deploy/bootstrap/local/**
!docs/deploy/environments/local/
!docs/deploy/environments/local/**

# IDE
.vs/
.prs/

# Claude Code local state
.claude/worktrees/
.claude/settings.json
.claude/settings.local.json
.claude/design_validate.json
.claude/scheduled_tasks.lock

# Cypilot plans (local working state)
cypilot/.plans/

# Codex App local config — hooks + agent shims installed per-developer
# when the Codex App scans the project. Not part of project source.
.codex/

# Codex App writes its own SKILL.md shims under .agents/skills/*/ when
# scanning the project. The canonical content lives in .claude/skills/
# and cypilot/.core/; the .agents/ scope is per-developer noise that
# would duplicate-track skill definitions across agent surfaces.
# Project files inside .agents/skills/<name>/ other than SKILL.md
# are NOT ignored — the directories themselves stay normal.
.agents/skills/*/SKILL.md

# Helm packaged dependencies (resolved by `helm dependency update`)
# Chart.lock IS committed for reproducibility — only the resolved tarballs are ignored.
charts/*/charts/*.tgz
charts/*/Chart.lock

# dbt logs
logs/
